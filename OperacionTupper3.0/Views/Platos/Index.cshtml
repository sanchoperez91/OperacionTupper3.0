@model IEnumerable<OperacionTupper3._0.Models.Platos>

@{
    ViewData["Title"] = "Index";
}

<h1 class="mb-4">Platos</h1>

<div class="mb-4">
    <a asp-action="Create" class="boton_anadir">+ Añadir</a>
</div>

<div class="contenedor-platos">
    @foreach (var plato in Model.OrderBy(p => p.Nombre_Plato))
    {
        <div class="card-plato">

            <div class="card-plato-titulo">
                @plato.Nombre_Plato
            </div>

            <div class="card-plato-contenido">

                <div class="dato-plato">
                    <span class="dato-titulo">Tipo:</span>
                    <span>@plato.TipoPlatoNavigation?.Nombre_TipoPlato</span>
                </div>

                <div class="dato-plato">
                    <span class="dato-titulo">Hora del día:</span>
                    <span>@plato.HoraDelDiaNavigation?.Nombre_HoraDelDia</span>
                </div>

            </div>

            <div class="acciones-plato">
                <a asp-action="Edit"
                   asp-route-idPlato="@plato.Id_Plato"
                   title="Editar">
                    ✏️
                </a>

                <a asp-action="Details"
                   asp-route-idPlato="@plato.Id_Plato"
                   title="Ver detalle">
                    👁️
                </a>

                <a asp-action="Delete"
                   asp-route-idPlato="@plato.Id_Plato"
                   title="Eliminar">
                    🗑️
                </a>
            </div>

        </div>
    }
</div>