@model OperacionTupper3._0.Models.Platos

@{
    ViewData["Title"] = "Details";
}

<h1>Detalle del plato</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Nombre:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nombre_Plato)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            Descripción:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descripcion_Plato)
        </dd>
    </dl>
        
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id_Plato">Editar</a> |
    <a asp-action="Index">Volver al listado</a>
</div>
