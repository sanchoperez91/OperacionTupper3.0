@model OperacionTupper3._0.Models.Platos

@{
    ViewData["Title"] = "Edit";
}

<h1>Editar plato</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id_Plato" />
            <div class="form-group">
                <label asp-for="Nombre_Plato" class="control-label">Nombre:</label>
                <input asp-for="Nombre_Plato" class="form-control" />
                <span asp-validation-for="Nombre_Plato" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Descripcion_Plato" class="control-label">Descripción</label>
                <input asp-for="Descripcion_Plato" class="form-control" />
                <span asp-validation-for="Descripcion_Plato" class="text-danger"></span>
            </div>
           
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver al listado</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
