@model OperacionTupper3._0.Models.Ingredientes

@{
    ViewData["Title"] = "Delete";
}

<h1>Eliminar</h1>

<h3>¿Estas seguro de querer eliminar este ingrediente?</h3>
<div>

    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Nombre:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nombre_Ingrediente)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
           Tipo:
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TipoIngredienteNavigation.Nombre_TipoIngrediente)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id_Ingrediente" />
        <input type="submit" value="Eliminar" class="btn btn-danger" /> |
        <a asp-action="Index">Volver al listado</a>
    </form>
</div>
